<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Direct access to index.html
  RewriteRule ^index\.html$ - [L]

  # 2. SPA Routing: Redirect all non-file/non-dir requests to index.html
  # This ensures React Router handles the URL (like /admin-login)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api [NC]
  RewriteRule . /index.html [L]
</IfModule>

# --- 🚀 Hostinger Node.js (Passenger) Configuration ---
# This section tells the server to run the Node.js backend
PassengerAppRoot /home/u263673950/domains/campaignsquat.com/nodejs
PassengerAppType node
PassengerNodejs /opt/alt/alt-nodejs20/root/bin/node
PassengerStartupFile server/index.js
PassengerBaseURI /
PassengerRestartDir /home/u263673950/domains/campaignsquat.com/nodejs/tmp

# Environment Variables
SetEnv NODE_ENV production
SetEnv PORT 3000